include README.md
include LICENSE
include CHANGELOG.md
include pyproject.toml
include plugins/lv2/pipetune-safeguard.lv2/manifest.ttl
include plugins/lv2/pipetune-safeguard.lv2/pipetune-safeguard.ttl
include plugins/lv2/pipetune-safeguard.lv2/pipetune_safeguard.c
include plugins/lv2/pipetune-safeguard.lv2/Makefile
recursive-include docs *.md
recursive-include examples *.txt
recursive-include tests *.py
recursive-include tests/fixtures *.csv
global-exclude *.py[cod]
global-exclude *.so
global-exclude *.o
global-exclude *.d
global-exclude *.tmp
global-exclude *~
global-exclude .DS_Store
prune .venv
prune __pycache__
prune .pytest_cache
prune dist
prune build
prune *.egg-info
prune generated
prune reports
prune measurements
prune verification/microphone
