__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.local-pipetune-test/
pipetune-install-test/
*.install-state.json

# Generated reports
reports/*.json
reports/*.md
!reports/.gitkeep

# Generated PipeWire configs
generated/*.conf
generated/*.manifest.json
generated/*.preflight.json
generated/*.safety.json
!generated/.gitkeep

# Generated microphone verification files
verification/microphone/*.wav
verification/microphone/*.json
verification/microphone/*.txt
!verification/.gitkeep
!verification/microphone/.gitkeep

# Local measurement files
measurements/
profiles/**/*.toml

# Local plugin build artifacts
plugins/lv2/**/*.so

# Local raw hardware audits
docs/system-audits/**/raw/
docs/system-audits/**/*.txt
docs/system-audits/**/hda-codec-files/

# Keep public/sanitized audit docs
!docs/system-audits/**/README.md
!docs/system-audits/**/FIX_PLAN.md
!docs/system-audits/**/PUBLIC_SUMMARY.md
!docs/system-audits/**/.gitkeep
