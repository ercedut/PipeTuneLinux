__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/

# Generated reports
reports/*.json
reports/*.md
!reports/.gitkeep

# Generated PipeWire configs
generated/*.conf
!generated/.gitkeep

# Local raw hardware audits
docs/system-audits/**/raw/
docs/system-audits/**/*.txt
docs/system-audits/**/hda-codec-files/

# Keep public/sanitized audit docs
!docs/system-audits/**/README.md
!docs/system-audits/**/FIX_PLAN.md
!docs/system-audits/**/PUBLIC_SUMMARY.md
!docs/system-audits/**/.gitkeep
