@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix lv2: <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .

<https://pipetune.local/plugins/pipetune-safeguard>
    a lv2:Plugin ;
    doap:name "PipeTune Safeguard" ;
    doap:license <https://spdx.org/licenses/MIT.html> ;
    lv2:requiredFeature lv2:hardRTCapable ;
    rdfs:comment "Conservative PipeTune safeguard plugin: preamp/headroom, high-pass filter, and hard safety limiter. It is not an enhancer and is not installed automatically." ;
    lv2:port [
        a lv2:AudioPort , lv2:InputPort ;
        lv2:index 0 ;
        lv2:symbol "in_l" ;
        lv2:name "Input L"
    ] , [
        a lv2:AudioPort , lv2:InputPort ;
        lv2:index 1 ;
        lv2:symbol "in_r" ;
        lv2:name "Input R"
    ] , [
        a lv2:AudioPort , lv2:OutputPort ;
        lv2:index 2 ;
        lv2:symbol "out_l" ;
        lv2:name "Output L"
    ] , [
        a lv2:AudioPort , lv2:OutputPort ;
        lv2:index 3 ;
        lv2:symbol "out_r" ;
        lv2:name "Output R"
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 4 ;
        lv2:symbol "preamp_db" ;
        lv2:name "Preamp / Headroom" ;
        lv2:default -6.0 ;
        lv2:minimum -24.0 ;
        lv2:maximum 0.0 ;
        units:unit units:db
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 5 ;
        lv2:symbol "highpass_hz" ;
        lv2:name "High-pass Frequency" ;
        lv2:default 120.0 ;
        lv2:minimum 60.0 ;
        lv2:maximum 250.0 ;
        units:unit units:hz
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 6 ;
        lv2:symbol "limiter_ceiling_db" ;
        lv2:name "Limiter Ceiling" ;
        lv2:default -1.0 ;
        lv2:minimum -12.0 ;
        lv2:maximum -0.1 ;
        units:unit units:db
    ] , [
        a lv2:ControlPort , lv2:InputPort ;
        lv2:index 7 ;
        lv2:symbol "bypass" ;
        lv2:name "Bypass" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] .

